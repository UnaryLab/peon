# NOTE: this .env is AUTHORITATIVE. It is loaded with override=True, so every
# value here OVERRIDES any matching variable exported in your shell. This applies
# to ALL config below, including SESSIONS_PATH and the *_TIMEOUT_MIN vars,
# which take effect from .env even though they are read early at import time.

# --- Slack credentials: ONE app per agent, two tokens each (required) ---
# Each agent is its own Slack app. Tokens come from env vars suffixed by the
# agent's uppercased name. Bot token starts with "xoxb-" (OAuth & Permissions,
# after installing the app); app-level token starts with "xapp-" and needs the
# connections:write scope (Basic Information -> App-Level Tokens).
# An agent is started only if BOTH of its tokens are set; the rest are skipped.

# Aristotle
SLACK_BOT_TOKEN_ARISTOTLE=xoxb-aristotle-bot-token
SLACK_APP_TOKEN_ARISTOTLE=xapp-aristotle-app-token

# Brunel
SLACK_BOT_TOKEN_BRUNEL=xoxb-brunel-bot-token
SLACK_APP_TOKEN_BRUNEL=xapp-brunel-app-token

# Cicero
SLACK_BOT_TOKEN_CICERO=xoxb-cicero-bot-token
SLACK_APP_TOKEN_CICERO=xapp-cicero-app-token

# Dijkstra (Codex-backed; optional, uncomment + fill in to enable)
SLACK_BOT_TOKEN_DIJKSTRA=xoxb-dijkstra-bot-token
SLACK_APP_TOKEN_DIJKSTRA=xapp-dijkstra-app-token

# --- Model & reasoning effort: configured in agents.json, NOT here ---
# Each agent's "model" and "effort" live in its agents.json entry (the single
# source of truth). There is no env-var override for them; edit agents.json to
# change a model or effort. Only the timeouts below remain env-configurable.

# --- Claude runner config (optional) ---
# Max MINUTES to wait for one headless claude run before timing out. Default 2880 (2 days).
CLAUDE_TIMEOUT_MIN=2880

# --- Codex runner config (optional; only matters if a Codex-backed agent like
# Dijkstra is configured) ---
# Max MINUTES to wait for one headless codex run before timing out. Default 2880 (2 days).
CODEX_TIMEOUT_MIN=2880

# --- Usage footer (optional; shared by both backends) ---
# When truthy, append a one-line usage footer under each reply, e.g.
#   · 4% · 12.3k tok · $0.04 · 18s   (claude)
#   · 14.0k tok · 9s                 (codex: no context-% or cost reported)
# Each field is omitted when unavailable. AUTHORITATIVE like the rest of this
# file (read live, so a SIGHUP .env reload takes effect). Default ON; set to
# 0/false/no/off (case-insensitive) to disable.
SHOW_USAGE=true

# --- Streaming output (optional; shared by both backends) ---
# When ON (the DEFAULT), the reply is posted incrementally to Slack as the CLI
# produces it (the "thinking..." placeholder is edited ~1x/sec with the partial
# text), then finalized with the full text + usage footer. Claude runs with
# --output-format stream-json; codex consumes its existing --json stdout. The
# final reply is identical to non-streaming. AUTHORITATIVE like the rest of this
# file (read live, so a SIGHUP .env reload takes effect). Set to 0/false/no/off
# (case-insensitive) to force the legacy single-shot path (one final update, no
# incremental edits). Default ON.
STREAM_OUTPUT=1

# --- SECURITY NOTE: agents run with full unsandboxed machine access ---
# Every run is fully unsandboxed (claude --permission-mode bypassPermissions, codex
# -s danger-full-access): a Slack-reachable agent has full read/write access to this
# machine (any absolute path, any command) with no approval step. Deliberate for a
# personal/lab deployment; restrict who can DM/mention these bots accordingly.

# --- Session store (shared by both backends) ---
# Path to the JSON session store. Defaults to ./sessions.json next to the code.
# Authoritative: a SESSIONS_PATH set here overrides the shell and redirects the
# store (resolved live at store access, so .env takes effect at import time too).
# The per-thread override store (overrides.json) and the Slack-native cron store
# (crons.json) are siblings of this path, so SESSIONS_PATH redirects all three
# together; there is NO separate env var for them.
SESSIONS_PATH=./sessions.json

# --- Cron scheduling (Slack-native; self-contained, NO env vars) ---
# A 60s scheduler thread fires enabled crons.json entries whose 5-field cron
# expression matches the current minute, posting into the cron's Slack thread.
# Manage from any thread with the control phrases:
#   !cron add "<min hour dom month dow>" <prompt>   (schedule a recurring run here)
#   !cron list | !cron remove <id> | !cron on <id> | !cron off <id>
# The store (crons.json) is a sibling of SESSIONS_PATH (see above) and survives a
# restart. NOTE: Claude Code has its own /schedule (cloud routines); this is the
# in-process Slack-native equivalent that runs inside this always-on process.
# There are NO cron env vars (the tick interval is a fixed 60s).

# --- Per-thread workdir (shared by both backends) ---
# WORKDIR_BASE: base directory for the per-thread workdir. Each thread gets its own
# subdir (namespaced by agent + thread), created on demand, and the run's cwd is
# set to it so files the agent produces there are uploaded back into the thread.
# The default is an ABSOLUTE path under your home dir (~/Projects/.peon-workdirs),
# OUTSIDE the repo so a run's default cwd is never the framework source. Read live
# (a SIGHUP .env reload takes effect).
# Default: ~/Projects/.peon-workdirs
WORKDIR_BASE=~/Projects/.peon-workdirs

# --- Pass-through environment for the CLI subprocess ---
# peon spawns `claude`/`codex` WITHOUT an explicit env=, so the subprocess (and
# any skill it runs) inherits this process's os.environ. load_env() copies every
# var defined here into os.environ at startup and on SIGHUP, so anything set in
# .env reaches the agent. Use this for vars a skill expects from the shell but
# that launchd/systemd do NOT inherit from your interactive login. Put it here,
# not in the deploy plist/.service (those are committed, OS-specific templates).
#
# OBSIDIAN_VAULT_PATH: absolute path to the Obsidian vault root (the folder
# containing research/). Required by the obsidian-* skills; without it a Slack
# run can't resolve the vault and refuses to write. Set it to your real path.
# OBSIDIAN_VAULT_PATH=/absolute/path/to/your/Obsidian-vault
